{
  "name": "cheque-printer",
  "version": "1.0.4",
  "description": "نظام إدارة وطباعة الشيكات — شهد وهبة للتمور / ميلانو للتمور",
  "author": "Shahd Wahba for Dates",
  "license": "UNLICENSED",
  "private": true,
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tailwindcss-rtl": "^0.9.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.shahdwahba.chequeprinter",
    "productName": "ChequeSystem",
    "copyright": "شهد وهبة للتمور",
    "asar": true,
    "forceCodeSigning": false,
    "files": [
      "main/**/*",
      "preload.js",
      "dist/**/*",
      "database/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "qahjoo",
        "repo": "cheque-printer"
      }
    ],
    "extraResources": [
      {
        "from": "database/migrations",
        "to": "database/migrations"
      },
      {
        "from": "build/fonts",
        "to": "build/fonts"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "cheque-printer-setup-${version}.${ext}",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "نظام الشيكات",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "runAfterFinish": true,
      "license": null,
      "menuCategory": "نظام الشيكات"
    },
    "portable": {
      "artifactName": "cheque-printer-portable-${version}.exe"
    }
  }
}
