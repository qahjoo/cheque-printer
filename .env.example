# =============================================================================
# .env.example — انسخ هذا الملف إلى .env واملأ القيم
# جميع القيم السرية (التوكنات وكلمات المرور) تُحفظ هنا فقط — لا تُخزَّن في قاعدة
# البيانات إطلاقاً. لا تشارك ملف .env مع أحد ولا ترفعه إلى Git.
# =============================================================================

# ---- Supabase (إلزامي للمزامنة السحابية) ------------------------------------
# رابط مشروع Supabase (من Project Settings > API)
SUPABASE_URL=
# المفتاح العام anon key (وليس service_role)
SUPABASE_ANON_KEY=

# ---- Telegram (اختياري — قناة تذكير) ----------------------------------------
# توكن البوت من BotFather
TELEGRAM_BOT_TOKEN=
# معرف المحادثة/القناة التي ستصلها التذكيرات
TELEGRAM_CHAT_ID=

# ---- البريد الإلكتروني SMTP (اختياري — قناة تذكير) --------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# عنوان المرسِل الظاهر (اختياري — الافتراضي SMTP_USER)
SMTP_FROM=
# المستلم الذي تصله التذكيرات
SMTP_TO=

# ---- عام --------------------------------------------------------------------
# بيئة التشغيل (development أثناء التطوير)
NODE_ENV=production
